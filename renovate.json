{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":configMigration"
  ],
  "enabledManagers": [
    "github-actions",
    "docker-compose",
    "custom.regex"
  ],
  "pinDigests": false,
  "github-actions": {
    "managerFilePatterns": [
      "/(^|/).github/workflows/[^/]+\\.ya?ml$/",
      "/(^|/).github/actions/[^/]+/action\\.ya?ml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track crane (go-containerregistry) pinned fallback versions",
      "managerFilePatterns": ["/.github/actions/setup-build-env/action\\.yml$/"],
      "matchStrings": ["CRANE_FALLBACK_VERSIONS=\\(\"(?<currentValue>v[\\d.]+)\""],
      "depNameTemplate": "google/go-containerregistry",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Track timescale/timescaledb-ha pg<N> major in smoke service container (pg18 → pg19 → ...)",
      "managerFilePatterns": [
        "/(^|/)\\.github/workflows/smoke-test\\.ya?ml$/",
        "/(^|/)\\.github/smoke/compose\\.ya?ml$/"
      ],
      "matchStrings": [
        "image:\\s+(?<depName>timescale/timescaledb-ha):(?<currentValue>pg\\d+)"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "regex:^pg(?<major>\\d+)$"
    }
  ],
  "labels": [
    "dependencies",
    "automated",
    "github-actions"
  ],
  "assignees": [
    "mekayelanik"
  ],
  "reviewers": [
    "mekayelanik"
  ],
  "timezone": "Asia/Dhaka",
  "schedule": [
    "before 6am on monday"
  ],
  "automerge": true,
  "platformAutomerge": false,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "rebaseWhen": "behind-base-branch",
  "prConcurrentLimit": 10,
  "prHourlyLimit": 5,
  "minimumReleaseAge": "0 days",
  "internalChecksFilter": "strict",
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ],
    "minimumReleaseAge": null
  },
  "packageRules": [
    {
      "description": "Disable pin and digest updates globally",
      "matchUpdateTypes": [
        "pin",
        "digest"
      ],
      "enabled": false
    },
    {
      "description": "GitHub Actions: major versions only; disable minor/patch",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "enabled": false
    },
    {
      "description": "GitHub Actions: major updates as PRs",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "labels": [
        "dependencies",
        "github-actions"
      ],
      "groupName": "github-actions-major"
    },
    {
      "description": "TimescaleDB-HA pg<N> bump: auto-merge — only used by the smoke-test infrastructure, never shipped in published images. Smoke battery itself acts as the regression gate; if it passes against the new pg<N>, the bump is safe to merge automatically.",
      "matchPackageNames": [
        "timescale/timescaledb-ha"
      ],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "labels": [
        "dependencies",
        "smoke-test",
        "database"
      ],
      "commitMessageTopic": "TimescaleDB ({{depName}})",
      "prBodyNotes": [
        "**Smoke test impact:** This bumps the PostgreSQL+TimescaleDB version used by `.github/workflows/smoke-test.yml` and `.github/smoke/compose.yml`. Auto-merge is enabled — the smoke battery itself runs against the new image as part of CI; if every status check passes, the PR auto-merges. If a TimescaleDB API change breaks the battery, smoke fails and Renovate holds the PR open for manual fix."
      ]
    }
  ],
  "commitMessagePrefix": "ci: ",
  "commitMessageAction": "update",
  "commitMessageTopic": "{{depName}}",
  "gitIgnoredAuthors": [
    "renovate[bot]@users.noreply.github.com"
  ]
}
