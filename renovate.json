{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":configMigration"
  ],
  "pinDigests": false,
  "labels": [
    "dependencies",
    "automated"
  ],
  "assignees": [
    "mekayelanik"
  ],
  "reviewers": [
    "mekayelanik"
  ],
  "timezone": "Asia/Dhaka",
  "schedule": [
    "before 6am on monday"
  ],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 5,
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ],
    "minimumReleaseAge": null
  },
  "packageRules": [
    {
      "description": "Disable pin and digest updates globally",
      "matchUpdateTypes": [
        "pin",
        "digest"
      ],
      "enabled": false
    },
    {
      "description": "GitHub Actions — major versions only (e.g. @v4 → @v5). Never automerge, never update minor/patch.",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "enabled": false
    },
    {
      "description": "GitHub Actions — open PR for major updates only, require manual review",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Security-related actions — major only, high priority",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "security-actions",
      "prPriority": 10,
      "labels": [
        "dependencies",
        "github-actions",
        "security",
        "priority"
      ],
      "matchPackageNames": [
        "/^aquasecurity\\//",
        "/^securego\\//",
        "/^github\\/codeql/"
      ]
    },
    {
      "description": "Core GitHub Actions (checkout, setup, upload/download) — major only",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "github-core-actions",
      "prPriority": 5,
      "labels": [
        "dependencies",
        "github-actions"
      ],
      "matchPackageNames": [
        "/^actions\\//"
      ]
    },
    {
      "description": "Docker ecosystem actions — major only",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "docker-actions",
      "prPriority": 3,
      "labels": [
        "dependencies",
        "github-actions",
        "docker"
      ],
      "matchPackageNames": [
        "/^docker\\//"
      ]
    },
    {
      "description": "All other GitHub Actions — major only",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "other-github-actions",
      "prPriority": 1,
      "labels": [
        "dependencies",
        "github-actions"
      ],
      "matchPackageNames": [
        "!/^actions\\//",
        "!/^docker\\//",
        "!/^aquasecurity\\//",
        "!/^securego\\//",
        "!/^github\\/codeql/"
      ]
    },
    {
      "description": "Dockerfile base images — group all into one PR, require manual review",
      "matchManagers": [
        "dockerfile"
      ],
      "groupName": "dockerfile-base-images",
      "prPriority": 4,
      "automerge": false,
      "labels": [
        "dependencies",
        "docker",
        "dockerfile"
      ],
      "matchPackageNames": [
        "golang",
        "alpine",
        "tonistiigi/xx"
      ]
    },
    {
      "description": "Automerge minor and patch for non-actions, non-dockerfile stable packages",
      "matchManagers": [
        "!github-actions",
        "!dockerfile"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    }
  ],
  "customManagers": [
    {
      "description": "Track upstream FreePeak/db-mcp-server repo for new commits — triggers workflow dispatch on new main branch SHA",
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/docker-publish\\.yml$/"
      ],
      "matchStrings": [
        "UPSTREAM_REPO_SHA:\\s*(?<currentValue>[a-f0-9]{40})"
      ],
      "depNameTemplate": "FreePeak/db-mcp-server",
      "packageNameTemplate": "https://github.com/FreePeak/db-mcp-server",
      "datasourceTemplate": "git-refs",
      "versioningTemplate": "git"
    }
  ],
  "commitMessagePrefix": "ci: ",
  "commitMessageAction": "update",
  "commitMessageTopic": "{{depName}}",
  "gitIgnoredAuthors": [
    "renovate[bot]@users.noreply.github.com"
  ]
}
